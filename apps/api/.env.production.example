# Production API environment (Render / Neon / Supabase)
# Copy to apps/api/.env for local prod testing, OR set in Render Dashboard → Environment.
# Never commit apps/api/.env (gitignored).

NODE_ENV=production
PORT=10000
WEB_ORIGIN=https://peblo-infinity-oss-web.vercel.app

# Render: Dashboard → peblo-infinityos-db → Connect → External Database URL
# Neon: pooled URL for app; use direct URL for prisma migrate (see RENDER_DEPLOY.md)
# Supabase: Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/peblo_infinityos?sslmode=require

JWT_ACCESS_SECRET=generate-with-openssl-rand-base64-48
JWT_REFRESH_SECRET=generate-another-long-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

DEMO_EMAIL=demo@peblo.infinityos.app
DEMO_PASSWORD=DemoInfinity2026!
DEMO_NAME=Demo visitor

# Optional
# REDIS_URL=redis://...
# MAIL_FROM="Peblo InfinityOS <noreply@yourdomain.com>"
# RESEND_API_KEY=re_...
# OPENAI_API_KEY=sk-...
