# Local development — copy to .env (gitignored):  copy .env.example .env
# Production — use Render Dashboard env vars + apps/api/.env.production.example

PORT=4000
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000

# Embedded Postgres (npm run dev:all) or Docker (npm run docker:up)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/peblo_infinityos?schema=public

JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

DEMO_EMAIL=demo@peblo.infinityos.app
