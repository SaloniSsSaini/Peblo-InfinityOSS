# Copy to apps/web/.env.local and apps/api/.env as needed

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000
# Optional: override defaults shown on /auth/login (must match API seed env if you change them)
# NEXT_PUBLIC_DEMO_EMAIL=demo@peblo.infinityos.app
# NEXT_PUBLIC_DEMO_PASSWORD=DemoInfinity2026!
# Set to 1 to hide the demo panel on the login page
# NEXT_PUBLIC_HIDE_DEMO_LOGIN=

# API (NestJS)
PORT=4000
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://peblo:peblo@localhost:5432/peblo_infinityos?schema=public
# Redis — cache (search, notes list, AI usage) + BullMQ mail queue when set
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# Optional: dedicated secret for password-reset JWTs (defaults to JWT_REFRESH_SECRET)
# PASSWORD_RESET_SECRET=
# Dev only: return resetUrl in forgot-password response when NODE_ENV=production
# PASSWORD_RESET_EXPOSE_TOKEN=1

# Password reset email (production) — configure one transport:
# Required when sending: verified sender address (Resend domain or SMTP From)
# MAIL_FROM="Peblo InfinityOS <noreply@yourdomain.com>"
#
# Option A — Resend (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
#
# Option B — SMTP (Gmail app password, SendGrid, Mailgun, etc.)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# Demo user (Prisma seed — run: cd apps/api && npx prisma db seed)
# Defaults match the web login panel when NEXT_PUBLIC_* are unset.
DEMO_EMAIL=demo@peblo.infinityos.app
DEMO_PASSWORD=DemoInfinity2026!
DEMO_NAME=Demo visitor

# AI (Stage 1+)
OPENAI_API_KEY=
GEMINI_API_KEY=
# Rolling 24h summarize quota per user (default 50)
# AI_DAILY_REQUEST_LIMIT=50

# OAuth (Stage 1)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
