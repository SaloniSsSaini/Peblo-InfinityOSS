# Production — copy to your host (e.g. apps/api/.env on the server)
# Generate secrets: openssl rand -base64 48

NODE_ENV=production
PORT=4000
WEB_ORIGIN=https://your-domain.com

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/peblo_infinityos?schema=public

# Recommended (cache + background mail). Optional: app runs without it.
REDIS_URL=redis://:PASSWORD@redis-host:6379

JWT_ACCESS_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_LONG_RANDOM_STRING
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Password reset — required if users can forget passwords in production
MAIL_FROM="Peblo InfinityOS <noreply@yourdomain.com>"
RESEND_API_KEY=re_REPLACE_ME

# Or SMTP instead of Resend:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=

# Demo seed — disable or change in production
# DEMO_EMAIL=
# DEMO_PASSWORD=

# Optional — real AI summaries
# OPENAI_API_KEY=sk-...
